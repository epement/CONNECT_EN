{$X+,O+,F+}
unit KeyName;

interface

function GetKeyName(Key: Word): String;

implementation

function GetKeyName(Key: Word): String;
begin
  case Key of
	0: GetKeyName := '';
    $011B: GetKeyName := 'Esc';
    $0100: GetKeyName := 'Alt+Back';
    $0200: GetKeyName := 'Alt+Space';
    $0300: GetKeyName := 'Ctrl+@';
    $0400: GetKeyName := 'Ctrl+Ins';
    $0500: GetKeyName := 'Shift+Ins';
    $0600: GetKeyName := 'Ctrl+Del';
    $0700: GetKeyName := 'Shift+Del';
    $0800: GetKeyName := 'Ctrl+Up';
    $0900: GetKeyName := 'Ctrl+Down';
    $0A00: GetKeyName := 'Alt+Right';
    $0B00: GetKeyName := 'Alt+Left';
    $0C00: GetKeyName := 'Alt+Up';
    $0D00: GetKeyName := 'Alt+Down';
    $0E00: GetKeyName := 'Alt+Ins';
    $0E08: GetKeyName := 'Back';
    $0E7F: GetKeyName := 'Ctrl+Back';
    $0F00: GetKeyName := 'Shift+Tab';
    $0F09: GetKeyName := 'Tab';
    $1000: GetKeyName := 'Alt+Q';
