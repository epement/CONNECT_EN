    $4200: GetKeyName := 'F8';
    $4300: GetKeyName := 'F9';
    $4400: GetKeyName := 'F10';
    $4700: GetKeyName := 'Home';
    $4800: GetKeyName := 'Up';
    $4900: GetKeyName := 'PgUp';
